# ============================================
# LexCore Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================

# ----- PostgreSQL Database -----
# Strong password for PostgreSQL (min 16 characters recommended)
POSTGRES_PASSWORD=YourStrongPassword123!

# ----- JWT Authentication -----
# Secret key for JWT token signing (min 64 characters)
# Generate with: openssl rand -base64 64
JWT_SECRET=YourVeryLongAndSecureJwtSecretKeyThatShouldBeAtLeast64CharactersLong!

# ----- Email Configuration (Gmail SMTP) -----
# For Gmail, enable 2FA and create an App Password
# https://myaccount.google.com/apppasswords
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM_ADDRESS=your-email@gmail.com

# ----- File Storage -----
# Set to 'true' for local storage, 'false' for AWS S3
STORAGE_USE_LOCAL=true

# AWS S3 Configuration (only needed if STORAGE_USE_LOCAL=false)
S3_BUCKET_NAME=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-south-1

# ----- Razorpay Payment Gateway -----
# Set to 'true' for test mode (mocked payments)
RAZORPAY_TEST_MODE=true

# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=

# ----- Application -----
# Base URL for email links (no trailing slash)
APP_BASE_URL=http://localhost:5000

# ----- CORS -----
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
